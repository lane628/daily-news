[{"id": 1, "title": "36氪首发 | 获宁德时代旗下基金领投数千万美元，智能出行公司上市首月已成印尼电摩品类订单第一", "summary": "智能出行公司OMOWAY（目蔚科技）近期完成数千万美元A轮和A+轮融资，其中A+轮由宁德时代旗下基金Lochpine Capital领投。其首款产品OMO-X在印尼上市首月即登顶全国电摩品类订单量第一，凭借智能化配置和自研技术架构打破日系燃油车主导的市场格局。公司计划以印尼为起点，逐步拓展泰国、新加坡及欧洲市场。", "image_url": "https://img.36krcdn.com/hsossms/20260702/v2_fa6b125ee79c453f9932c2e78ffe3617@5836910_oswg487705oswg1080oswg608_img_000?x-oss-process=image/format,jpg/interlace,1", "date": "2026-07-03", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/p/3877990989819909?f=rss"}, {"id": 2, "title": "36氪首发 | 省级实验室团队做电氢耦合解决方案，获厦门高新投领投", "summary": "厦门启航氢能技术有限公司近日完成新一轮融资，由厦门高新投领投，资金将用于电氢耦合关键装备及离网制氢技术的研发与产品迭代。公司技术源于嘉庚创新实验室，核心团队在电力电子与电化学领域有近20年积累，已开发出覆盖30kW至20MW的制氢电源等产品，并合作超过50家电解槽企业。启航氢能定位为第三方氢能电气装备供应商，其优势在于工程化能力、对电解槽材料机理的研究以及快速的产品迭代速度。", "image_url": "https://img.36krcdn.com/hsossms/20260703/v2_d65587b6160049309e342b0f083fb440@5920579_oswg147836oswg675oswg592_img_000?x-oss-process=image/format,jpg/interlace,1", "date": "2026-07-03", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/p/3879274157928449?f=rss"}, {"id": 3, "title": "8点1氪丨“具身智能第一股” 宇树科技上市申请通过；SK海力士单日市值蒸发10000亿元；配置失误引发0元抢购潮，霸王茶姬致歉", "summary": "证监会同意宇树科技科创板IPO注册，该公司成为全球首家在IPO前实现人形机器人规模化盈利的企业，创下科创板最快审核纪录。亚太股市重挫，SK海力士单日市值蒸发约10000亿元人民币，三星电子跌9%。霸王茶姬因配置失误导致新品标价变为0元引发抢购潮，公司致歉并取消订单，向受影响用户发放补偿券。", "image_url": "https://img.36krcdn.com/hsossms/20260703/v2_2318e6832c5a474dac4c52c059d693c7@5667365_oswg194047oswg1080oswg1389_img_000?x-oss-process=image/format,jpg/interlace,1", "date": "2026-07-03", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/p/3879158039834629?f=rss"}, {"id": 4, "title": "氪星晚报｜证监会同意宇树科技科创板IPO注册；Meta“带崩”科技股？业内人士：算力过剩系误读", "summary": "证监会同意宇树科技科创板IPO注册；Meta出售算力被误读为算力过剩，业内人士澄清并非AI资本支出结束；奥飞娱乐、盐湖股份等公司发布业绩预告，净利润大幅增长。", "image_url": "", "date": "2026-07-02", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/p/3878550357946625?f=rss"}, {"id": 5, "title": "谁能想到，系统流「爽文」最先被AI Agent实现了", "summary": "联想天禧AI推出定制短剧《我的AI搭档之“禧”从天降》，将网文中的“系统流”概念与职场现实结合，讲述职场新人叶天在获得天禧AI后，通过系统辅助化解上司打压、PPT被删等危机，实现逆袭的故事。短剧通过叶天被要求当天完成全部门三个月未啃下的赛事营销方案等情节，展示了AI Agent在速推方案、云端恢复进度、实时翻译等场景中的实际能力。该剧旨在让观众直观理解AI Agent的功能，而非单纯解释技术名词。", "image_url": "https://img.36krcdn.com/hsossms/20260702/v2_479f75a076024a17bafa8bcb0cb1a26d@5362858_oswg1152334oswg900oswg1030_img_000?x-oss-process=image/format,jpg/interlace,1", "date": "2026-07-02", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/p/3878522627518471?f=rss"}, {"id": 6, "title": "36氪 AI 工具测评，正在找第一批「抢跑者」", "summary": "36氪推出AI工具测评“抢跑营”，旨在帮助用户打破信息茧房，提升AI工具使用效率。该社群面向深度使用者与新手，要求成员每日分享真实使用体验，并提供深度资料、圈子交流及平台曝光等资源支持。参与者需积极共创，避免长期潜水或广告引流。", "image_url": "", "date": "2026-07-02", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/p/3878412963508486?f=rss"}, {"id": 7, "title": "享道被困16%“平台税”", "summary": "享道出行再次向港交所递交招股书，2025年营收67.74亿元，净亏损收窄至2.46亿元，毛利率升至11.0%。但活跃司机数同比下滑9%，98.5%订单依赖高德、滴滴等聚合平台，2025年支付佣金5.56亿元。公司计划与上汽、Momenta合作发展Robotaxi，但研发费用仅9540万元，面临资金和流量挑战。", "image_url": "https://img.36krcdn.com/hsossms/20260702/v2_1c9b3239454d4c3184c6fd05b79b13b8@5426566_oswg103165oswg554oswg329_img_000?x-oss-process=image/format,jpg/interlace,1", "date": "2026-07-02", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/p/3878254740549638?f=rss"}, {"id": 8, "title": "秋声 | 净利从8.4亿跌到1987万，深圳光伏老兵靠储能再冲港股", "summary": "古瑞瓦特第三次向港交所递交招股书，其净利润在2023至2025年间经历剧烈波动，从8.4亿元跌至1987万元再回升至4.1亿元。利润下滑主因是欧洲能源危机退潮导致需求下降和去库存促销，而2023年利润中包含3.6亿元非现金收益。公司收入结构已从光伏逆变器为主转向储能系统，2025年储能收入占比达63.4%，且现金流充裕，资产负债率仅9.2%。", "image_url": "https://img.36krcdn.com/hsossms/20260702/v2_64041329f27645ec8dcd25569a74fee6@430412560_oswg4040oswg900oswg145_img_000?x-oss-process=image/format,jpg/interlace,1", "date": "2026-07-02", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/p/3878131056701447?f=rss"}, {"id": 9, "title": "36氪首发 | 清华、中科院团队联合华西医院研发康养转运机器人，进一步布局居家养老场景", "summary": "可立点科技完成战略融资，由力合科创领投，资金将用于产品研发和商业化落地。该公司与华西医院联合研发的GR-150康复助行转运机器人，以及面向家庭的陪伴机器人，均已完成样机开发，预计2026年启动量产。创始人王禹衡和CEO张腾腾等核心团队来自清华、中科院，公司已布局数十项专利，正申请医疗器械注册。", "image_url": "https://img.36krcdn.com/hsossms/20260702/v2_d822f015fb6843539d7ba3dcc5ed901c@5920579_oswg92507oswg674oswg379_img_000?x-oss-process=image/format,jpg/interlace,1", "date": "2026-07-02", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/p/3877863381741577?f=rss"}, {"id": 10, "title": "36氪首发 | 前大疆科学家创业，半年内连获四轮数亿融资，耀途资本、锦秋基金等押注", "summary": "硅羽科技（SPARO）半年内连续完成四轮数亿元融资，投资方包括耀途资本、锦秋基金、阿里巴巴等，资金将用于团队建设、产品商业化及技术迭代。公司由前大疆科学家张富创立，专注于通用空中智能，致力于让飞行器在无GPS等复杂环境中自主完成任务。其核心技术壁垒在于全栈自研的感知、决策与协同体系，已积累数十家种子客户。", "image_url": "https://img.36krcdn.com/hsossms/20260702/v2_29d41b66367f47e6b55f35a6f4aa1c37@6221844_oswg550778oswg1068oswg612_img_000?x-oss-process=image/format,jpg/interlace,1", "date": "2026-07-02", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/p/3877830625046535?f=rss"}, {"id": 11, "title": "多家品牌金饰价格大涨，周生生克价1266元", "summary": "7月3日，国内多家品牌金饰价格大幅上涨，周生生足金首饰报价1266元/克，较前一日涨30元；老凤祥、周大福、老庙黄金分别报1260元/克、1262元/克、1261元/克，涨幅在26至30元之间。", "image_url": "", "date": "2026-07-03", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/newsflashes/3879312159518982?f=rss"}, {"id": 12, "title": "“格式塔科技”完成4.2亿元天使+轮融资", "summary": "格式塔科技完成4.2亿元天使+轮融资，由华映资本领投，C资本、红杉中国、蓝思科技等多家机构跟投。老股东道彤投资、云时资本等持续超额加码认购，华兴资本担任独家财务顾问。", "image_url": "", "date": "2026-07-03", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/newsflashes/3879309800058888?f=rss"}, {"id": 13, "title": "机构：日本可能正在采取新的外汇干预策略", "summary": "星展集团研究部高级外汇策略师Philip Wee指出，日本可能正采取新的外汇干预策略，有传言称财务省或将转向不公开的隐秘干预。Wee表示，在美国独立日假期导致市场流动性稀薄的情况下，此类干预可能加剧波动。他认为，日本新策略旨在将市场心理从怀疑转为谨慎。", "image_url": "", "date": "2026-07-03", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/newsflashes/3879308887568387?f=rss"}, {"id": 14, "title": "沪深两市成交额突破1.5万亿", "summary": "沪深两市成交额突破1.5万亿元。该数据由36氪报道。", "image_url": "", "date": "2026-07-03", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/newsflashes/3879305411440640?f=rss"}, {"id": 15, "title": "华为技术公司增资至约411.4亿", "summary": "华为技术有限公司注册资本由约410.4亿人民币增至约411.4亿人民币。该公司成立于1987年9月，法定代表人为赵明路，由华为投资控股有限公司全资持股。此次增资涉及信息系统设计、集成及运行维护等业务范围。", "image_url": "", "date": "2026-07-03", "category": "internet", "source": "36氪", "source_url": "https://36kr.com/newsflashes/3879302367637760?f=rss"}, {"id": 16, "title": "让Agent越用越强：AReaL 2.0开源，打造面向自演进智能体的RL基础设施", "summary": "AReaL 2.0正式开源，这是一套面向自演进智能体的强化学习基础设施，旨在让AI Agent越用越强。该项目通过开源方式与社区合作，共同推动自演进智能体生态的发展。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "量子位", "source_url": "https://www.qbitai.com/2026/07/442134.html"}, {"id": 17, "title": "全球首个英伟达含量为0的万亿模型，成了海外开发者的抢手货", "summary": "全球首个完全不使用英伟达芯片的万亿参数模型在OpenR榜单上霸榜，成为海外开发者的热门选择。该模型打破了英伟达在AI算力领域的垄断地位，引发业界广泛关注。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "量子位", "source_url": "https://www.qbitai.com/2026/07/442047.html"}, {"id": 18, "title": "科大讯飞举办智能交互生态发布会，三大平台同步升级", "summary": "科大讯飞举办智能交互生态发布会，宣布旗下三大平台同步升级。此次升级聚焦于提升语音识别、自然语言处理等核心技术的性能，并新增多项开发者工具。具体升级细节及数据未在摘要中提及。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "量子位", "source_url": "https://www.qbitai.com/2026/07/442048.html"}, {"id": 19, "title": "论坛预告｜夯！AI企业家论坛首发阵容公开，更有千亿级实业巨头突袭", "summary": "7月17日至20日将举办AI企业家论坛，首发阵容已公布，包括千亿级实业巨头在内的重磅嘉宾将参与。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "量子位", "source_url": "https://www.qbitai.com/2026/07/442037.html"}, {"id": 20, "title": "天工 3.2 重磅升级：Skywork Tags 上线，给 Agent 一张工牌，邀其加入你的工作群聊", "summary": "天工3.2版本迎来重大升级，新增Skywork Tags功能，为AI Agent配备“工牌”身份标识。该功能允许用户将Agent直接加入工作群聊，实现与人类员工并肩协作的工作模式。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "量子位", "source_url": "https://www.qbitai.com/2026/07/442030.html"}, {"id": 21, "title": "钉钉A1录音卡入选Gartner AI可穿戴设备报告", "summary": "钉钉A1录音卡入选Gartner AI可穿戴设备报告。该报告指出，AI硬件的终局不在于参数比拼，而在于是否拥有真正的企业级AI协作平台。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "量子位", "source_url": "https://www.qbitai.com/2026/07/442024.html"}, {"id": 22, "title": "招募｜量子位RSS’26专题策划", "summary": "量子位将于2026年7月13日至17日在澳大利亚悉尼举办RSS’26专题策划活动，目前正在招募参与者。该活动聚焦量子计算领域，具体议程和报名方式待公布。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "量子位", "source_url": "https://www.qbitai.com/2026/07/442016.html"}, {"id": 23, "title": "一个广告营销老炮，率先冲刺A股无人驾驶第一股", "summary": "一家由资深广告营销人士创立的无人驾驶公司正冲刺A股，有望成为该领域第一股。其最大客户赛力斯贡献了全年三成收入，凸显业务高度依赖单一客户。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "量子位", "source_url": "https://www.qbitai.com/2026/07/441790.html"}, {"id": 24, "title": "天工AI业务ARR突破8亿美元，向中国首个非BAT10亿美元ARR的AI公司迈进", "summary": "天工AI业务年度经常性收入（ARR）突破8亿美元，其中AI短剧平台业务ARR超过7亿美元。该公司正朝着成为中国首个非BAT阵营中达到10亿美元ARR的AI公司目标迈进。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "量子位", "source_url": "https://www.qbitai.com/2026/07/441786.html"}, {"id": 25, "title": "训练世界模型，开始从人类的肌肉和脑子里偷师了", "summary": "具身智能数据采集领域出现新范式，通过直接从人类的肌肉活动和脑电信号中“偷师”来训练世界模型。这种方法突破了传统依赖传感器或人工标注的局限，显著提升了机器人对物理世界的理解与模仿能力。相关研究团队已展示初步成果，但具体数据和人名尚未公开。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "量子位", "source_url": "https://www.qbitai.com/2026/07/441725.html"}, {"id": 26, "title": "AI Agent 的 Skill 系统设计", "summary": "本文系统阐述了AI Agent Skill系统的设计理念，将Skill视为“行为编程”而非文档，通过YAML+Markdown、DOT流程图等结构化设计及门控、合理化防御等约束机制规范代理行为。文章提出了在有限上下文窗口下的Token经济策略，包括基于触发条件的发现机制、两阶段加载及声明式引用，并设计了单向管道工作流编排、子代理上下文隔离及分级模型选择方案。同时，强调了基于TDD理念的Skill测试方法，通过压力场景观测并封堵代理的异常行为。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "AI星球", "source_url": "https://www.aixq.cc/47599.html"}, {"id": 27, "title": "向量检索、知识图谱与 LLM Wiki：RAG 被嘲笑了三年，但企业还是离不开它", "summary": "尽管RAG技术曾因效果不佳被多次嘲讽，但它仍是企业知识库的主流方案。大模型仅掌握公域知识，容易产生幻觉，因此需要外挂知识库来提供可信的私域知识参考。然而，企业知识库的内容管理仍面临新的挑战。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "AI星球", "source_url": "https://www.aixq.cc/47624.html"}, {"id": 28, "title": "AI互联网日报：阿里整合 QoderWork、悟空和 MuleRun；Kimi 推出语音通话模式；Gemini Spark 登陆 Mac", "summary": "阿里巴巴整合QoderWork、悟空和MuleRun，筹备新的生产力AI产品；Kimi推出语音通话模式，强化陪伴功能；Gemini Spark登陆Mac平台。同时，华为鸿蒙与美团骑手保障将数字能力落地于设备与人。AI的发展趋势正从单纯追求智能转向更自然地融入用户日常场景。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "AI星球", "source_url": "https://www.aixq.cc/47402.html"}, {"id": 29, "title": "computer-science：是一张通往硅谷的船票吗？", "summary": "GitHub上拥有20万Stars的ossu/computer-science项目并非代码库，而是一张整合了MIT、哈佛、普林斯顿等顶尖大学计算机科学核心课程的免费课程清单。该项目旨在让用户通过约两年时间，在线完成相当于本科CS学位的主体学习内容。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "AI星球", "source_url": "https://www.aixq.cc/47248.html"}, {"id": 30, "title": "javascript-algorithms：前端学算法的第一站", "summary": "trekhleb/javascript-algorithms 是一个 GitHub 排名前25的纯教育性仓库，收录约105个算法和数据结构实现，每个都附带独立README文档。该项目自2018年创建以来，明确声明仅供学习和研究使用，不发布npm包或承诺API稳定性。", "image_url": "", "date": "2026-07-02", "category": "ai", "source": "AI星球", "source_url": "https://www.aixq.cc/47157.html"}, {"id": 31, "title": "��������", "summary": "由于您未提供具体的新闻标题和内容，我无法为您生成摘要。请提供新闻的标题和正文内容，我将为您提炼2-3句核心信息。", "image_url": "", "date": "2026-07-02", "category": "finance", "source": "同花顺", "source_url": "http://stock.10jqka.com.cn/thsgd/"}, {"id": 32, "title": "�������ù���", "summary": "抱歉，您提供的内容中标题和正文均显示为乱码，无法识别有效信息。请重新提供正确的新闻标题和内容。", "image_url": "", "date": "2026-07-02", "category": "finance", "source": "同花顺", "source_url": "http://data.10jqka.com.cn/market/ggsd/ggtype/2/#refCountId=www_52201297_5095"}, {"id": 33, "title": "�����¶ȼ�", "summary": "标题和内容均为乱码，无法提取有效信息。请提供正确的新闻标题和内容。", "image_url": "", "date": "2026-07-02", "category": "finance", "source": "同花顺", "source_url": "http://stock.10jqka.com.cn/wenduji/"}, {"id": 34, "title": "�鿴��վ��ͼ\n            >", "summary": "由于提供的新闻标题和内容存在乱码，无法准确提取核心信息。请提供清晰的新闻文本，以便生成符合要求的摘要。", "image_url": "", "date": "2026-07-02", "category": "finance", "source": "同花顺", "source_url": "http://www.10jqka.com.cn/sitemap_index.shtml"}, {"id": 35, "title": "���貨����й����й�˾Э����ҵ������Ϳվ���רҵίԱ